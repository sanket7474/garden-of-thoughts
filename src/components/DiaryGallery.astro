---
interface DiaryImage {
  src: string;
  alt?: string;
  caption?: string;
}

interface Props {
  images: DiaryImage[];
  label?: string;
}

const { images, label = "from my diary" } = Astro.props;
---

<div class="diary-gallery">
  <p class="diary-gallery__label">{label}</p>

  <div class="diary-gallery__grid">
    {images.map((img, i) => (
      <button
        class="diary-gallery__thumb"
        data-index={String(i)}
        aria-label={img.alt ?? `Diary page ${i + 1}`}
        type="button"
      >
        <img
          src={img.src}
          alt={img.alt ?? `Diary page ${i + 1}`}
          loading="lazy"
          decoding="async"
        />
        <span class="diary-gallery__expand-icon" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
          </svg>
        </span>
      </button>
    ))}
  </div>
</div>

<div
  class="diary-lightbox"
  id="diary-lightbox"
  role="dialog"
  aria-modal="true"
  aria-label="Diary page viewer"
  hidden
>
  <button class="diary-lightbox__backdrop" id="diary-lb-backdrop" type="button" aria-label="Close lightbox"></button>

  <div class="diary-lightbox__stage">
    <button class="diary-lightbox__close" id="diary-lb-close" type="button" aria-label="Close">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </button>

    <button class="diary-lightbox__nav diary-lightbox__nav--prev" id="diary-lb-prev" type="button" aria-label="Previous page">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
    </button>

    <div class="diary-lightbox__frame">
      <img class="diary-lightbox__img" id="diary-lb-img" src="" alt="" />
      <div class="diary-lightbox__meta">
        <p class="diary-lightbox__caption" id="diary-lb-caption"></p>
        <span class="diary-lightbox__counter" id="diary-lb-counter"></span>
      </div>
    </div>

    <button class="diary-lightbox__nav diary-lightbox__nav--next" id="diary-lb-next" type="button" aria-label="Next page">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 18l6-6-6-6"/>
      </svg>
    </button>
  </div>
</div>

<style>
  /* ── Gallery grid ─────────────────────────────────────── */
  .diary-gallery {
    margin: 2.5rem 0;
  }

  .diary-gallery__label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.90;
    margin: 0 0 0.85rem 0;
    color: var(--text-color);
  }

  .diary-gallery__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
    gap: 8px;
  }

  .diary-gallery__thumb {
    all: unset;
    position: relative;
    display: block;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: 3px;
    border: 1px solid var(--border-color);
    background: var(--background-color);
    cursor: url("/pointer.png") 0 0, pointer;
  }

  .dark-mode .diary-gallery__thumb {
    cursor: url("/pointer-dark.png") 0 0, pointer;
  }

  .diary-gallery__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease, filter 0.3s ease;
    filter: sepia(12%) contrast(0.95);
  }

  .diary-gallery__thumb:hover img {
    transform: scale(1.05);
    filter: sepia(0%) contrast(1);
  }

  .diary-gallery__expand-icon {
    position: absolute;
    bottom: 6px;
    right: 6px;
    width: 24px;
    height: 24px;
    border-radius: 2px;
    background: var(--background-color);
    border: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-color);
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .diary-gallery__thumb:hover .diary-gallery__expand-icon {
    opacity: 0.85;
  }

  /* ── Lightbox ─────────────────────────────────────────── */
  .diary-lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }

  .diary-lightbox[hidden] {
    display: none;
  }

  .diary-lightbox__backdrop {
    all: unset;
    position: absolute;
    inset: 0;
    background: rgba(11, 23, 51, 0.9);
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    cursor: url("/pointer.png") 0 0, pointer;
  }

  .dark-mode .diary-lightbox__backdrop {
    background: rgba(5, 6, 20, 0.93);
    cursor: url("/pointer-dark.png") 0 0, pointer;
  }

  .diary-lightbox__stage {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    max-width: 700px;
    width: 100%;
    animation: lb-appear 0.2s ease;
  }

  @keyframes lb-appear {
    from { opacity: 0; transform: translateY(10px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .diary-lightbox__frame {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .diary-lightbox__img {
    max-height: 82vh;
    max-width: 100%;
    width: auto;
    object-fit: contain;
    display: block;
    border-radius: 2px;
    box-shadow: 0 16px 56px rgba(0, 0, 0, 0.65);
    filter: sepia(6%);
    transition: opacity 0.15s ease;
  }

  .diary-lightbox__img.is-fading {
    opacity: 0;
  }

  .diary-lightbox__meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .diary-lightbox__caption {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-style: italic;
    color: rgba(242, 240, 233, 0.9);
    text-align: center;
    margin: 0;
    min-height: 1em;
  }

  .diary-lightbox__counter {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(242, 240, 233, 0.80);
  }

  /* Nav */
  .diary-lightbox__nav {
    all: unset;
    flex-shrink: 0;
    width: 38px;
    height: 38px;
    border-radius: 2px;
    border: 1px solid rgba(242, 240, 233, 0.80);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(242, 240, 233, 0.80);
    transition: background 0.18s, border-color 0.18s, color 0.18s;
    cursor: url("/pointer.png") 0 0, pointer;
  }

  .dark-mode .diary-lightbox__nav {
    cursor: url("/pointer-dark.png") 0 0, pointer;
  }

  .diary-lightbox__nav:hover {
    background: rgba(242, 240, 233, 0.08);
    border-color: rgba(242, 240, 233, 0.32);
    color: rgba(242, 240, 233, 0.9);
  }

  .diary-lightbox__nav:disabled {
    opacity: 0.20;
    pointer-events: none;
  }

  /* Close */
  .diary-lightbox__close {
    all: unset;
    position: absolute;
    top: -2.75rem;
    right: 0;
    width: 30px;
    height: 30px;
    border-radius: 2px;
    border: 1px solid rgba(242, 240, 233, 0.60);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(242, 240, 233, 0.80);
    transition: color 0.18s, border-color 0.18s;
  }
  @media (min-width: 640px) {
    .diary-lightbox__close {
        top: -0.50rem;
    }
}
  

  .diary-lightbox__close:hover {
    color: rgba(242, 240, 233, 0.9);
    border-color: rgba(242, 240, 233, 0.80);
  }

  @media (max-width: 480px) {
    .diary-lightbox__nav { display: none; }
    .diary-lightbox__stage { padding: 0 0.5rem; }
  }
</style>

<script define:vars={{ images }}>
  const lightbox = document.getElementById('diary-lightbox');
  const lbImg    = document.getElementById('diary-lb-img');
  const lbCap    = document.getElementById('diary-lb-caption');
  const lbCount  = document.getElementById('diary-lb-counter');
  const lbPrev   = document.getElementById('diary-lb-prev');
  const lbNext   = document.getElementById('diary-lb-next');
  const lbClose  = document.getElementById('diary-lb-close');
  const lbBack   = document.getElementById('diary-lb-backdrop');

  let current = 0;

  function open(index) {
    current = index;
    render();
    lightbox.hidden = false;
    document.body.style.overflow = 'hidden';
    lbClose.focus();
  }

  function close() {
    lightbox.hidden = true;
    document.body.style.overflow = '';
  }

  function go(index) {
    lbImg.classList.add('is-fading');
    setTimeout(() => {
      current = index;
      render();
      lbImg.classList.remove('is-fading');
    }, 140);
  }

  function render() {
    const img = images[current];
    lbImg.src = img.src;
    lbImg.alt = img.alt ?? `Diary page ${current + 1}`;
    lbCap.textContent   = img.caption ?? '';
    lbCount.textContent = `${current + 1} / ${images.length}`;
    lbPrev.disabled = current === 0;
    lbNext.disabled = current === images.length - 1;
  }

  document.querySelectorAll('.diary-gallery__thumb').forEach(btn => {
    btn.addEventListener('click', () => open(Number(btn.dataset.index)));
  });

  lbPrev.addEventListener('click', () => { if (current > 0) go(current - 1); });
  lbNext.addEventListener('click', () => { if (current < images.length - 1) go(current + 1); });
  lbClose.addEventListener('click', close);
  lbBack.addEventListener('click', close);

  document.addEventListener('keydown', e => {
    if (lightbox.hidden) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft'  && current > 0)                go(current - 1);
    if (e.key === 'ArrowRight' && current < images.length - 1) go(current + 1);
  });

  // Swipe on mobile
  let tx = 0;
  lightbox.addEventListener('touchstart', e => { tx = e.touches[0].clientX; }, { passive: true });
  lightbox.addEventListener('touchend',   e => {
    const dx = e.changedTouches[0].clientX - tx;
    if (Math.abs(dx) < 40) return;
    if (dx < 0 && current < images.length - 1) go(current + 1);
    if (dx > 0 && current > 0)                 go(current - 1);
  });
</script>