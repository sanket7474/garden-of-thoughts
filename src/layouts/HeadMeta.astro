---
type Props = {
  title: string;
  description: string;
  permalink: string;
  canonicalUrl?: string;
  image?: string;
  type?: 'website' | 'article';
};

const { 
  title, 
  description, 
  canonicalUrl, 
  permalink,
  image,
  type = 'website'
} = Astro.props;

const SITE_NAME = "Garden of Thoughts";
const DEFAULT_IMAGE = "https://sanketmaske.dev/favicon.png";
const ogImage = image || DEFAULT_IMAGE;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="manifest" href="/site.webmanifest" />
<link rel="mask-icon" href="/safari-pinned-tab.svg" color="#5bbad5" />
<meta name="msapplication-TileColor" content="#da532c" />
<meta name="theme-color" content="#181b3a" />

<link rel="webmention" href="https://webmention.io/sanketmaske.dev/webmention" />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content="Sanket Maske" />
{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={permalink} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="200" />
<meta property="og:image:height" content="200" />
<meta property="og:locale" content="en_US" />

<!-- Twitter / X -->
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:creator" content="@sanket_maske" />