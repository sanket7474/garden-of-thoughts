---
type Props = {
  page: string;
};

import Sidebar from './Sidebar.astro';
import Footer from './Footer.astro';

const { page } = Astro.props;
---

<style>
  .container {
    max-width: 80ch;
    grid-column-start: 2;
    box-sizing: border-box;
    padding: 0 1em;
    position: relative;
  }

  @media (min-width: 640px) {
    .container {
      padding: 1em 1em 1em 2em;
    }
  }

  @media (min-width: 930px) {
    .container {
      padding: 1em 1em 1em 3em;
    }
  }

  @media (min-width: 640px) {
    .grid-container {
      display: grid;
      grid-template-columns: minmax(220px, 20vw) 1fr;
    }
  }

  @media (min-width: 1440px) {
    .grid-container {
      grid-template-columns: 286px 1fr;
    }
  }

  body {
    font-family: var(--font-mono);
  }
</style>

<Sidebar page={page} />
<div class="grid-container">
  <div class="container">
    <main>
      <slot />
    </main>
    <Footer />
  </div>
</div>

<script>
  const path = window.location.pathname;
  const ENABLE_TRACKING = true; 
  // Only trigger for blog posts
  if (ENABLE_TRACKING && ( path.startsWith("/blog/") || path.startsWith("/about") || path.startsWith("/subscribe")) {
    navigator.sendBeacon(
      "/.netlify/functions/page-hit",
      JSON.stringify({ path })
    );
  }
</script>