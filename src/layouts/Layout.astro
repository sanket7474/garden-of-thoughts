---
type Props = {
  page: string;
};

import Sidebar from './Sidebar.astro';
import Footer from './Footer.astro';
import Vines from './Vines.astro';

const { page } = Astro.props;
---

<style>
  .container {
    max-width: 80ch;
    grid-column-start: 2;
    box-sizing: border-box;
    padding: 0 1em;
    position: relative;
  }

  @media (min-width: 640px) {
    .container {
      padding: 1em 1em 1em 2em;
    }
  }

  @media (min-width: 930px) {
    .container {
      padding: 1em 1em 1em 3em;
    }
  }

  @media (min-width: 640px) {
    .grid-container {
      display: grid;
      grid-template-columns: minmax(220px, 20vw) 1fr;
    }
  }

  @media (min-width: 1440px) {
    .grid-container {
      grid-template-columns: 286px 1fr;
    }
  }

  body {
    font-family: var(--font-mono);
  }
</style>

<Sidebar page={page} />
<div class="grid-container">
  <div class="container">
    <main>
      <slot />
    </main>
    <Vines />
    <Footer />
  </div>
</div>

<script>
  const ENABLE_TRACKING = import.meta.env.PROD;

  function getDeviceId() {
    let id = localStorage.getItem("device-id");

    if (!id) {
      id = crypto.randomUUID();
      localStorage.setItem("device-id", id);
    }

    return id;
  }

  function getDevice() {
    return /Mobi|Android/i.test(navigator.userAgent)
      ? "📱 Mobile"
      : "💻 Desktop";
  }

  function getBrowser() {
    const ua = navigator.userAgent;

    if (ua.includes("Chrome") && !ua.includes("Edg")) return "🌐 Chrome";
    if (ua.includes("Safari") && !ua.includes("Chrome")) return "🌐 Safari";
    if (ua.includes("Firefox")) return "🌐 Firefox";
    if (ua.includes("Edg")) return "🌐 Edge";

    return "🌐 Unknown";
  }

  function getReferrer() {
    if (!document.referrer) return "Direct";
    try {
      return new URL(document.referrer).hostname;
    } catch {
      return document.referrer;
    }
  }

  const path = window.location.pathname;

  function isDoNotTrackEnabled() {
    return (
      navigator.doNotTrack === "1" ||
      // @ts-ignore
      window.doNotTrack === "1" ||
      // @ts-ignore
      navigator.msDoNotTrack === "1"
    );
  }

  function sendPageHit() {
    const returning = localStorage.getItem("visited") === "true";
    localStorage.setItem("visited", "true");

    navigator.sendBeacon(
      "/.netlify/functions/page-hit",
      JSON.stringify({
        path,
        device: getDevice(),
        browser: getBrowser(),
        referrer: getReferrer(),
        userAgent: navigator.userAgent,
        returning,
        deviceId: getDeviceId(),
      })
    );
  }

  if (ENABLE_TRACKING && !isDoNotTrackEnabled()) {
    if ("requestIdleCallback" in window) {
      // @ts-ignore
      requestIdleCallback(sendPageHit, { timeout: 1500 });
    } else {
      setTimeout(sendPageHit, 300);
    }
  }
</script>