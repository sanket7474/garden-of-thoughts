---
import HeadMeta from "./HeadMeta.astro";

interface Props {
  title: string;
  description: string;
  permalink: string;
  canonicalUrl?: string;
  includeYTResources?: boolean | null;
}

let { title, description, permalink, canonicalUrl, includeYTResources } =
  Astro.props;
---

<head>
  <HeadMeta
    title={title}
    description={description}
    canonicalUrl={canonicalUrl}
    permalink={permalink}
  />

  <script src="./configurations.ts"></script>
  {
    includeYTResources && (
      <link rel="stylesheet" href="/assets/styles/lite-yt-embed.css" />
    )
  }

  
  <link rel="stylesheet" href="/styles/global.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cascadia+Mono:ital,wght@0,400;0,500;0,700;1,400&family=Lora:ital,wght@0,400;1,400;1,500&family=Karla:ital,wght@0,300;0,400;0,500;1,400&family=Bungee&display=swap"
    rel="stylesheet"
  />
</head>
