---
import HeadMeta from "./HeadMeta.astro";

interface Props {
  title: string;
  description: string;
  permalink: string;
  canonicalUrl?: string;
  includeYTResources?: boolean | null;
}

let { title, description, permalink, canonicalUrl, includeYTResources } =
  Astro.props;
---

<head>
  <HeadMeta
    title={title}
    description={description}
    canonicalUrl={canonicalUrl}
    permalink={permalink}
  />

  <script src="./configurations.ts"></script>
  {
    includeYTResources && (
      <link rel="stylesheet" href="/assets/lite-yt-embed.css" />
    )
  }

  <style is:global>
  
  </style>
  <link rel="stylesheet" href="/styles/global.css" />
</head>
