---
type Props = {
  page: string;
};

const { page } = Astro.props;
---

<style>
  .sidebar {
    min-width: 220px;
    text-align: right;
    box-sizing: border-box;
    padding: 10% 10% 0 10%;
    position: relative;
  }

  @media (min-width: 640px) {
    .sidebar {
      position: fixed;
      width: 20vw;
      padding: 4em 1em 3em 2em;
    }

    @media (max-height: 630px) {
      .sidebar {
        position: absolute;
      }
    }
  }

  @media (min-width: 1440px) {
    .sidebar {
      width: 286px;
    }
  }

  .site-name-link {
    text-decoration: none;
  }

  .site-name {
    font-size: 8vw;
    margin: 0;
    margin-bottom: 1em;
    margin-right: -30%;
    line-height: 1.1;
    text-align: right;
    text-transform: uppercase;
    transform: skew(-10deg) rotate(-10deg);
    display: flex;
    flex-direction: column;
    align-items: center;
    font-family: "Cascadia Mono", sans-serif;
    font-optical-sizing: auto;
    font-weight: 800;
    font-style: normal;
  }

  @media (min-width: 640px) {
    .site-name {
      font-size: 2rem;
      margin-right: -20px;
      
    }
  }

  .site-name span {
    display: inline-block;
    position: relative;
  }

  .site-name span::after {
    content: "";
    display: block;
    position: absolute;
    width: 104%;
    left: -2%;
    height: 130%;
    top: -5%;
    z-index: -1;
  }

  .site-name span:nth-child(1)::after {
    background: hsla(18, 87%, 53%, 0.5);
  }
  .site-name span:nth-child(2)::after {
    background: hsla(49, 93%, 51%, 0.5);
  }
  .site-name span:nth-child(3)::after {
    background: hsla(253, 45%, 47%, 0.5);
  }

  .nav {
    font-size: 1.34rem;
  }

  .nav ul {
    list-style: none;
    align-items: right;
    margin: 0;
    padding: 0;
    display: flex;
    justify-content: flex-end;
  }

  @media (min-width: 640px) {
    .nav {
      font-size: 1.2rem;
    }

    .nav ul {
      grid-template-columns: none;
      display: grid;
    }
  }

  .nav li {
    text-transform: uppercase;
    margin-bottom: 0.4em;
    padding-left: 1em;
  }

  .nav li a {
    text-decoration: none;
    font-size: 1.1em;
    position: relative;
    display: block;
    transition: padding-right 0.2s ease-in-out;
    line-height: 1.2;
  }

  .nav li a.rss-link {
    display: flex;
  }

  .nav li a.rss-link span {
    display: none;
  }

  @media (min-width: 640px) {
    .nav li a.nav-link:hover,
    .nav li a.nav-link.active {
      padding-right: 10px;
    }

    .nav li a.nav-link::after {
      content: "";
      display: block;
      width: 4px;
      height: 0;
      background: var(--accent-color);
      transition: width 0.3s;
      position: absolute;
      right: 0;
      top: 13px;
      border-radius: 2px;
      transition:
        height 0.1s ease-out,
        top 0.1s ease-out;
    }

    :global(.rainbows) .nav li a.nav-link::after {
      background: var(--gradient-color);
    }

    .nav li a.nav-link:hover::after,
    .nav li a.nav-link.active::after {
      height: 17px;
      top: 5px;
      transition:
        height 0.2s ease-in,
        top 0.2s ease-in;
    }

    .nav li a.rss-link span {
      display: inherit;
    }
  }

  .settings {
    display: flex;
    justify-content: flex-end;
    padding: 0px;
  }

  @media (min-width: 640px) {
    .settings {
      display: block;
      margin-top: 1em;
    }
  }

  .settings li {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1.2em;
    column-gap: 0.5em;
    font-size: 1.1rem;
    font-family: var(--font-mono);
    line-height: 1;
    margin-bottom: 0.8em;
    margin-left: 0.6em;
    align-items: center;
  }

  .settings li.cursor-trails-setting {
    display: none;
  }

  input[type="checkbox"] {
    -webkit-appearance: none;
    appearance: none;
    margin: 0;
    font: inherit;
    color: currentColor;
    width: 1.15em;
    height: 1.15em;
    border: 0.15em solid currentColor;
    border-radius: 0.2em;
    transform: translateY(-0.075em);
    display: grid;
    place-content: center;
  }

  input[type="checkbox"]::before {
    content: "";
    width: 0.65em;
    height: 0.65em;
    transform: scale(0);
    transition: 120ms transform ease-in-out;
    background-image: linear-gradient(
      45deg,
      var(--accent-color),
      var(--accent-color)
    );
  }

  :global(.rainbows) input[type="checkbox"]::before {
    background-image: var(--gradient-color);
  }

  input[type="checkbox"]:checked::before {
    transform: scale(1);
  }

  @media (min-width: 640px) {
    .settings li.cursor-trails-setting {
      display: grid;
    }

    .settings li {
      font-size: 1rem;
    }
  }

  .imgAnchor {
    
    display: block;
    height: 10vh;
  }

  .sidebar .imgAnchor .brandImg {
    position: absolute;
    width: 70vw;
    left: -20vw;
    top: -5%;
    display: block;
    z-index: 99999;
    transform: rotate(10deg) scale(1);
    transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    cursor: pointer;
  }

  .sidebar .imgAnchor .brandImg:hover {
    transform: rotate(10deg) scale(1.3);
  }

  @media (min-width: 640px) {
    .imgAnchor {
      margin-bottom: 10vh !important;
      display: block;
      height: 30vh;
    }

    .sidebar .imgAnchor .brandImg {
      width: 25vw;
      left: -5vw;
      min-height: 100px;
      top: 0;
    }
  }
</style>

<div class="sidebar">
  <div class="imgAnchor">
    <canvas id="peacock-canvas" class="brandImg"></canvas>
  </div>
  <a href="/" class="site-name-link"
    ><div class="site-name">
      <span>&nbspGarden&nbsp</span><span>&nbsp Of &nbsp</span><span>&nbspThoughts&nbsp</span>
    </div></a
  >
  <nav class="nav">
    <ul>
      <li>
        <a class:list={{ active: page === "posts", "nav-link": true }} href="/"
          >Posts</a
        >
      </li>
      <li>
        <a
          class:list={{ active: page === "tags", "nav-link": true }}
          href="/tags/">Tags</a
        >
      </li>
      <li>
        <a
          class:list={{ active: page === "about", "nav-link": true }}
          href="/about/">About</a
        >
      </li>
    </ul>
  </nav>

  <ul class="settings">
    <li class="cursor-trails-setting chckbx">
      <label for="cursor-trails">cursor trails</label><input
        id="cursor-trails"
        type="checkbox"
      />
    </li>
    <li class="chckbx">
      <label for="dark-mode">dark mode</label><input
        id="dark-mode"
        type="checkbox"
      />
    </li>
  </ul>
</div>

<script>
  const canvas = document.getElementById("peacock-canvas") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d")!;
  const SIZE = 1000;
  canvas.width = SIZE;
  canvas.height = SIZE;

  canvas.style.cursor = "pointer";
  canvas.addEventListener("click", () => (window.location.href = "/"));

   // Navigate on click
  canvas.addEventListener("click", () => (window.location.href = "/"));
 
  // Hover scale via JS — bypasses Astro CSS scoping issues
  canvas.addEventListener("mouseenter", () => {
    canvas.style.transform = "rotate(10deg) scale(1.3)";
  });
  canvas.addEventListener("mouseleave", () => {
    canvas.style.transform = "rotate(10deg) scale(1)";
  });

  const img = new Image();
  img.src = "/assets/images/peacock-compressed.png";

  img.onload = () => {
    const src = document.createElement("canvas");
    src.width = SIZE;
    src.height = SIZE;
    const sctx = src.getContext("2d")!;
    sctx.drawImage(img, 0, 0, SIZE, SIZE);
    const srcData = sctx.getImageData(0, 0, SIZE, SIZE);
    const out = ctx.createImageData(SIZE, SIZE);

    const JX = 600,
      JY = 560;
    const weights = new Float32Array(SIZE * SIZE);
    const progress = new Float32Array(SIZE * SIZE);

    for (let y = 0; y < SIZE; y++) {
      for (let x = 0; x < SIZE; x++) {
        const i = y * SIZE + x;
        const dx = x - JX,
          dy = y - JY;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist > 780) {
          weights[i] = 0;
          continue;
        }

        const angle = (Math.atan2(dy, dx) * 180) / Math.PI;
        const a360 = angle < 0 ? angle + 360 : angle;
        if (a360 > 215 && a360 < 315) {
          weights[i] = 0;
          continue;
        }

        const innerFade = dist < 180 ? (dist / 180) * (dist / 180) : 1;

        let angleFade = 1;
        const edgeSoft = 25;
        const distFrom215 = Math.min(
          Math.abs(a360 - 215),
          360 - Math.abs(a360 - 215)
        );
        const distFrom315 = Math.min(
          Math.abs(a360 - 315),
          360 - Math.abs(a360 - 315)
        );
        const nearestEdge = Math.min(distFrom215, distFrom315);
        if (nearestEdge < edgeSoft) angleFade = nearestEdge / edgeSoft;

        const prog = Math.min(1, Math.max(0, dist / 760));
        progress[i] = prog;
        const rampOut = prog > 0.9 ? (1 - prog) / 0.1 : 1;
        weights[i] = innerFade * angleFade * rampOut;
      }
    }

    let t = 0;
    function frame() {
      t += 0.050;
      const sd = srcData.data,
        od = out.data;
      for (let y = 0; y < SIZE; y++) {
        for (let x = 0; x < SIZE; x++) {
          const i = y * SIZE + x,
            idx = i * 4;
          const w = weights[i];
          if (w === 0) {
            od[idx] = sd[idx];
            od[idx + 1] = sd[idx + 1];
            od[idx + 2] = sd[idx + 2];
            od[idx + 3] = sd[idx + 3];
            continue;
          }
          const dist = Math.sqrt((x - JX) ** 2 + (y - JY) ** 2);
          const phase = dist * 0.01;
          const dispX = Math.sin(t - phase) * w * 11;
          const dispY = Math.sin(t * 1.6 - phase * 1.2 + 0.9) * w * 4;
          const micro = Math.sin(t * 3.1 - phase * 2.5 + x * 0.025) * w * 2.5;
          const sx = Math.max(
            0,
            Math.min(SIZE - 1, Math.round(x - dispX - micro))
          );
          const sy = Math.max(0, Math.min(SIZE - 1, Math.round(y - dispY)));
          const si = (sy * SIZE + sx) * 4;
          od[idx] = sd[si];
          od[idx + 1] = sd[si + 1];
          od[idx + 2] = sd[si + 2];
          od[idx + 3] = sd[si + 3];
        }
      }
      ctx.putImageData(out, 0, 0);
      requestAnimationFrame(frame);
    }
    frame();
  };

  
</script>