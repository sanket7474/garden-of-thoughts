---
import { getCollection } from 'astro:content';
import { monthNames } from '../data/postConfig';

// @ts-nocheck
// @ts-ignore

const allPosts = await getCollection('posts', ({ data }) => !data.draft);

allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const years:any = [];

allPosts.forEach(post => {
  const date = new Date(post.data.date);
  const yearNum = date.getFullYear();
  const monthNum = date.getMonth();
  const day = date.getDate().toString().padStart(2, '0');

  let year = years.find(y => y.date === yearNum);
  if (!year) {
    year = { date: yearNum, months: [] };
    years.push(year);
  }

  let month = year.months.find(m => m.date === monthNum);
  if (!month) {
    month = { date: monthNum, name: monthNames[monthNum], posts: [] };
    year.months.push(month);
  }

  month.posts.push({ ...post, day });
});

years.sort((a:any, b:any) => b.date - a.date);
years.forEach(y => y.months.sort((a:any, b:any) => b.date - a.date));
---
<style>

    .post-list {
      padding: 28px 0 60px;
    }

    .year-sep {
      display: block;
      font-size: 2.5rem;
      font-style: italic;
      font-weight: 400;
      color: var(--text-color);
      letter-spacing: -0.03em;
      padding: 44px 0 0;
      line-height: 1;
      opacity: 0.5;
      user-select: none;
      font-family: var(--mono);
    }

    .month-group {
      margin-top: 0;
    }

    .month-label {
      display: block;
      padding: 28px 0 10px;
      /* border-bottom: 2px solid black; */
    }

    .month-label span {
      font-size: 1.4rem;
      font-weight: 500;
      color: var(--text-color);
    }

    .post-row::before {
      content: "";
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 3px;
      transform: scaleY(0);
      transform-origin: center;
      transition: transform 0.2s ease;
    }

    .month-group .post-row:nth-child(7n + 1)::before {
      background: var(--red);
    }
    .month-group .post-row:nth-child(7n + 2)::before {
      background: var(--orange);
    }
    .month-group .post-row:nth-child(7n + 3)::before {
      background: var(--pink);
    }
    .month-group .post-row:nth-child(7n + 4)::before {
      background: var(--green);
    }
    .month-group .post-row:nth-child(7n + 5)::before {
      background: var(--light-blue);
    }
    .month-group .post-row:nth-child(7n + 6)::before {
      background: var(--purple);
    }
    .month-group .post-row:nth-child(7n + 0)::before {
      background: var(--blue);
    }

    .post-row:hover::before {
      transform: scaleY(1);
    }
    .post-row:hover .post-title {
      color: var(--c5);
    }

    .post-day {
      font-family: var(--font-mono);
      font-size: 1.2rem;
      font-weight: 500;
      padding-top: 1px;
      text-align: right;
      padding-right: 18px;
      user-select: none;
    }

    .month-group .post-row:nth-child(7n + 1) .post-day {
      color: var(--red);
    }
    .month-group .post-row:nth-child(7n + 2) .post-day {
      color: var(--orange);
    }
    .month-group .post-row:nth-child(7n + 3) .post-day {
      color: var(--pink);
    }
    .month-group .post-row:nth-child(7n + 4) .post-day {
      color: var(--green);
    }
    .month-group .post-row:nth-child(7n + 5) .post-day {
      color: var(--light-blue);
    }
    .month-group .post-row:nth-child(7n + 6) .post-day {
      color: var(--purple);
    }
    .month-group .post-row:nth-child(7n + 0) .post-day {
      color: var(--blue);
    }

    .tag:hover {
      opacity: 0.65;
    }

    .post-row:nth-child(1) .tag {
      color: var(--blue);
    }
    .post-row:nth-child(2) .tag {
      color: var(--purple);
    }
    .post-row:nth-child(3) .tag {
      color: var(--light-blue);
    }
    .post-row:nth-child(4) .tag {
      color: var(--pink);
    }
    .post-row:nth-child(5) .tag {
      color: var(--green);
    }
    .post-row:nth-child(6) .tag {
      color: var(--orange);
    }
    .post-row:nth-child(7) .tag {
      color: var(--red);
    }

    .post-row:nth-of-type(7n + 1):hover .post-title {
      color: var(--red);
    }
    .post-row:nth-of-type(7n + 2):hover .post-title {
      color: var(--orange);
    }
    .post-row:nth-of-type(7n + 3):hover .post-title {
      color: var(--pink);
    }
    .post-row:nth-of-type(7n + 4):hover .post-title {
      color: var(--green);
    }
    .post-row:nth-of-type(7n + 5):hover .post-title {
      color: var(--light-blue);
    }
    .post-row:nth-of-type(7n + 6):hover .post-title {
      color: var(--purple);
    }
    .post-row:nth-of-type(7n + 0):hover .post-title {
      color: var(--blue);
    }

    .divider {
  height: 1px;
  background: linear-gradient(to right, rgba(120, 130, 200, 0.4), transparent);
  border: none;
}
 .divider-full {
  height: 5px;
  background: rgba(120, 130, 200, 0.4); 
  border: none;
}
  </style>

<div class="post-list">
  <div class="col">
    {
     // @ts-nocheck
     // @ts-ignore
    years.map(year => (
      <>
        <span class="year-sep">{year.date}</span>
        { // @ts-ignore
        year.months.map(month => (
          <div class="month-group">
            <div class="month-label"><span>{month.name}</span></div>
            <div class="divider-full"></div>
            {month.posts.map((post:any) => (
              <div class="post-row" onclick={`window.location='/blog/${post.slug}'`}>
                <span class="post-day">{post.day}</span>
                <span class="post-title">
                  {post.data.title}
                  {
                    // @ts-nocheck
                    // @ts-ignore
                  post.data.tags.map(tag => (
                    <a href={`/tags/#${tag}`} class="tag">#{tag}</a>
                  ))}
                </span>
                
              </div>
              <div class="divider"></div>
            ))}
            
          </div>
        ))}
      </>
    ))}
  </div>
</div>

<script>
  // @ts-nocheck
     // @ts-ignore
  document.querySelectorAll('.post-title').forEach(title => {
    const tags = title.querySelectorAll('.tag');
    const colors = ['var(--red)', 'var(--orange)', 'var(--pink)', 'var(--green)', 'var(--light-blue)', 'var(--purple)', 'var(--blue)'];
    const shuffled = colors.sort(() => Math.random() - 0.5);
    tags.forEach((tag, i) => {
      tag.style.color = shuffled[i % shuffled.length];
    });
  });
</script>