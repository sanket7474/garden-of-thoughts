---
// src/pages/admin.astro
---

<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin — Garden of Thoughts</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;1,400;1,500&family=IBM+Plex+Mono:wght@400;500&family=Karla:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cascadia+Mono:ital,wght@0,200..700;1,200..700&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg:           #181b3a;
        --text:         #f2f0e9;
        --text-muted:   #c9c6d1;
        --border:       #2e3260;
        --card-bg:      #1e2248;
        --card-hover:   #232753;
        --accent:       #c76399;
        --green:        #48a71e;
        --red:          #db5c55;
        --purple:       #867cc0;
        --font-body:    'Karla', sans-serif;
        --font-mono:    'Cascadia Mono', monospace;
        --font-serif:   'Lora', serif;
      }

      html, body {
        height: 100%;
        background: var(--bg);
        color: var(--text);
        font-family: var(--font-body);
        font-size: 1rem;
        line-height: 1.6;
      }

      /* ── Login ───────────────────────────────────────── */
      #login-screen {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        gap: 0;
      }

      .login-box {
        width: 100%;
        max-width: 380px;
        padding: 2.5rem;
        border: 1px solid var(--border);
        border-radius: 16px;
        background: var(--card-bg);
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
      }

      .login-title {
        font-family: var(--font-serif);
        font-size: 1.6rem;
        font-style: italic;
        color: var(--text);
        margin-bottom: 0.2rem;
      }

      .login-subtitle {
        font-size: 0.85rem;
        color: var(--text-muted);
        font-family: var(--font-mono);
        letter-spacing: 0.04em;
      }

      .field-label {
        display: block;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 0.4rem;
      }

      .field-input {
        width: 100%;
        padding: 0.65rem 1rem;
        font-size: 1rem;
        font-family: var(--font-mono);
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--text);
        outline: none;
        transition: border-color 0.2s;
      }

      .field-input:focus { border-color: var(--accent); }

      .login-error {
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--red);
        display: none;
      }

      /* ── Buttons ─────────────────────────────────────── */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.55rem 1.2rem;
        font-size: 0.9rem;
        font-family: var(--font-mono);
        font-weight: 500;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: opacity 0.15s, transform 0.1s;
        letter-spacing: 0.02em;
      }

      .btn:hover:not(:disabled) { opacity: 0.88; transform: translateY(-1px); }
      .btn:active:not(:disabled) { transform: translateY(0); }
      .btn:disabled { opacity: 0.35; cursor: not-allowed; }

      .btn-primary  { background: var(--accent); color: white; width: 100%; justify-content: center; padding: 0.75rem; font-size: 1rem; }
      .btn-approve  { background: #1a3d1f; color: #4ade80; border: 1px solid #2d6b36; }
      .btn-reject   { background: #3d1a1a; color: #f87171; border: 1px solid #6b2d2d; }

      /* ── Admin layout ────────────────────────────────── */
      #admin-screen {
        display: none;
        max-width: 760px;
        margin: 0 auto;
        padding: 3rem 1.5rem 6rem;
      }

      .admin-header {
        margin-bottom: 2.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px dashed var(--border);
      }

      .admin-title {
        font-family: var(--font-serif);
        font-size: 2rem;
        font-style: italic;
        color: var(--text);
      }

      .admin-subtitle {
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-top: 0.3rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      /* ── Comment card ────────────────────────────────── */
      .comment-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.5rem;
        margin-bottom: 1.2rem;
        transition: background 0.2s;
        animation: fadeIn 0.3s ease both;
      }

      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      .comment-card:hover { background: var(--card-hover); }

      /* header row */
      .card-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
      }

      .card-author-block { display: flex; flex-direction: column; gap: 0.25rem; }

      .card-name {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--text);
      }

      .card-website {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        color: var(--accent);
        text-decoration: none;
        letter-spacing: 0.02em;
      }

      .card-website:hover { text-decoration: underline; }

      .card-badges {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.3rem;
      }

      .badge {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 0.72rem;
        letter-spacing: 0.05em;
        padding: 0.2rem 0.6rem;
        border-radius: 20px;
        white-space: nowrap;
      }

      .badge-slug {
        background: rgba(134,124,192,0.15);
        color: var(--purple);
        border: 1px solid rgba(134,124,192,0.3);
      }

      .badge-date {
        background: rgba(255,255,255,0.05);
        color: var(--text-muted);
        border: 1px solid var(--border);
      }

      /* labels */
      .card-section-label {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 0.4rem;
      }

      /* comment body */
      .card-body-wrap {
        margin-bottom: 1.2rem;
      }

      .card-body {
        font-size: 1rem;
        line-height: 1.65;
        color: var(--text);
        background: rgba(0,0,0,0.2);
        border-left: 3px solid var(--accent);
        padding: 0.8rem 1rem;
        border-radius: 0 8px 8px 0;
        white-space: pre-wrap;
        word-break: break-word;
      }

      /* post preview */
      .card-post-wrap { margin-bottom: 1.2rem; }

      .card-post-link {
        font-family: var(--font-mono);
        font-size: 0.82rem;
        color: var(--text-muted);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.3rem 0.7rem;
        border: 1px solid var(--border);
        border-radius: 6px;
        transition: color 0.15s, border-color 0.15s;
      }

      .card-post-link:hover { color: var(--text); border-color: var(--text-muted); }

      /* actions row */
      .card-actions {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        flex-wrap: wrap;
      }

      .card-status {
        font-family: var(--font-mono);
        font-size: 0.8rem;
        margin-left: auto;
        min-height: 1.4em;
      }

      .card-status.success { color: #4ade80; }
      .card-status.error   { color: var(--red); }

      /* ── States ──────────────────────────────────────── */
      #loading, #empty-state {
        text-align: center;
        padding: 4rem 0;
        color: var(--text-muted);
        font-family: var(--font-mono);
        font-size: 0.9rem;
        letter-spacing: 0.04em;
      }

      .loading-dots::after {
        content: '';
        animation: dots 1.4s infinite;
      }

      @keyframes dots {
        0%   { content: ''; }
        33%  { content: '.'; }
        66%  { content: '..'; }
        100% { content: '...'; }
      }

      .error-banner {
        background: rgba(219,92,85,0.1);
        border: 1px solid rgba(219,92,85,0.3);
        color: #f87171;
        padding: 1rem 1.2rem;
        border-radius: 10px;
        margin-bottom: 1.2rem;
        font-family: var(--font-mono);
        font-size: 0.85rem;
      }

      .count-badge {
        display: inline-block;
        background: rgba(199,99,153,0.15);
        border: 1px solid rgba(199,99,153,0.3);
        color: var(--accent);
        font-family: var(--font-mono);
        font-size: 0.75rem;
        padding: 0.15rem 0.55rem;
        border-radius: 20px;
        margin-left: 0.5rem;
        vertical-align: middle;
      }
    </style>
  </head>
  <body>

    <!-- ── Login ────────────────────────────────────────── -->
    <div id="login-screen">
      <div class="login-box">
        <div>
          <p class="login-title">🌱 Garden of Thoughts</p>
          <p class="login-subtitle">Admin · Comment Moderation</p>
        </div>
        <div>
          <label class="field-label" for="password-input">Password</label>
          <input class="field-input" type="password" id="password-input" placeholder="Enter password" autocomplete="current-password" />
        </div>
        <p class="login-error" id="login-error">Incorrect password. Try again.</p>
        <button class="btn btn-primary" id="login-btn">Enter</button>
      </div>
    </div>

    <!-- ── Admin ─────────────────────────────────────────── -->
    <div id="admin-screen">
      <div class="admin-header">
        <h1 class="admin-title">Comment Moderation</h1>
        <p class="admin-subtitle" id="admin-subtitle">Loading<span class="loading-dots"></span></p>
      </div>

      <div id="error-container"></div>
      <div id="loading">
        <span class="loading-dots">Fetching pending comments</span>
      </div>
      <div id="comments-container"></div>
      <div id="empty-state" style="display:none">
        ✦ No pending comments — you're all caught up
      </div>
    </div>

    <script>
      let sessionPassword = null;

      const loginScreen       = document.getElementById('login-screen');
      const adminScreen       = document.getElementById('admin-screen');
      const loginBtn          = document.getElementById('login-btn');
      const passwordInput     = document.getElementById('password-input');
      const loginError        = document.getElementById('login-error');
      const commentsContainer = document.getElementById('comments-container');
      const emptyState        = document.getElementById('empty-state');
      const loadingEl         = document.getElementById('loading');
      const errorContainer    = document.getElementById('error-container');
      const adminSubtitle     = document.getElementById('admin-subtitle');

      // ── Login ──────────────────────────────────────────
      loginBtn.addEventListener('click', handleLogin);
      passwordInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') handleLogin();
      });

      async function handleLogin() {
        loginBtn.disabled = true;
        loginBtn.textContent = 'Verifying...';
        loginError.style.display = 'none';

        const password = passwordInput.value;
        const res = await callAdmin({ action: 'list', password });

        if (res.error === 'Unauthorized') {
          loginError.style.display = 'block';
          passwordInput.value = '';
          loginBtn.disabled = false;
          loginBtn.textContent = 'Enter';
          return;
        }

        sessionPassword = password;
        loginScreen.style.display = 'none';
        adminScreen.style.display = 'block';

        const submissions = res.submissions || [];
        loadingEl.style.display = 'none';
        adminSubtitle.innerHTML = submissions.length === 0
          ? 'All caught up ✦'
          : `<span>${submissions.length} pending</span><span class="count-badge">${submissions.length}</span>`;

        renderSubmissions(submissions);
      }

      // ── API helpers ────────────────────────────────────
      async function callAdmin(body) {
        try {
          const res = await fetch('/api/admin-submissions', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });
          return res.json();
        } catch (e) {
          return { error: e.message };
        }
      }

      // ── Render ─────────────────────────────────────────
      function renderSubmissions(submissions) {
        commentsContainer.innerHTML = '';

        if (submissions.length === 0) {
          emptyState.style.display = 'block';
          return;
        }

        submissions.forEach((sub, i) => {
          const { id, data, created_at } = sub;
          const { name, comment, slug, website } = data;

          const date = new Date(created_at).toLocaleDateString('en-US', {
            year: 'numeric', month: 'short', day: 'numeric',
            hour: '2-digit', minute: '2-digit'
          });

          const card = document.createElement('div');
          card.className = 'comment-card';
          card.id = `card-${id}`;
          card.style.animationDelay = `${i * 60}ms`;

          card.innerHTML = `
            <div class="card-header">
              <div class="card-author-block">
                <span class="card-name">👤 ${escHtml(name)}</span>
                ${website
                  ? `<a class="card-website" href="${escHtml(website)}" target="_blank" rel="noopener">⤤ ${escHtml(website)}</a>`
                  : `<span class="card-website" style="color:var(--text-muted)">No website</span>`
                }
              </div>
              <div class="card-badges">
                <span class="badge badge-slug">📄 ${escHtml(slug)}</span>
                <span class="badge badge-date">🕐 ${date}</span>
              </div>
            </div>

            <div class="card-body-wrap">
              <p class="card-section-label">Comment</p>
              <div class="card-body">${escHtml(comment)}</div>
            </div>

            <div class="card-post-wrap">
              <p class="card-section-label">Post</p>
              <a class="card-post-link" href="/blog/${escHtml(slug)}" target="_blank" rel="noopener">
                /blog/${escHtml(slug)} ↗
              </a>
            </div>

            <div class="card-actions">
              <button class="btn btn-approve" data-id="${id}">✅ Approve</button>
              <button class="btn btn-reject"  data-id="${id}">❌ Reject</button>
              <span class="card-status" id="status-${id}"></span>
            </div>
          `;

          commentsContainer.appendChild(card);
        });

        document.querySelectorAll('.btn-approve').forEach((btn) =>
          btn.addEventListener('click', () => handleApprove(btn.dataset.id, submissions))
        );
        document.querySelectorAll('.btn-reject').forEach((btn) =>
          btn.addEventListener('click', () => handleReject(btn.dataset.id))
        );
      }

      // ── Approve ────────────────────────────────────────
      async function handleApprove(submissionId, submissions) {
        const sub = submissions.find((s) => s.id === submissionId);
        setCardLoading(submissionId, true);
        setStatus(submissionId, 'Pushing to GitHub...', '');

        try {
          const approveRes = await fetch('/api/comment-approved', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ data: sub.data }),
          });
          if (!approveRes.ok) throw new Error('GitHub push failed');

          const deleteRes = await callAdmin({
            action: 'delete',
            password: sessionPassword,
            submissionId,
          });
          if (deleteRes.error) throw new Error(deleteRes.error);

          setStatus(submissionId, '✅ Approved & live soon!', 'success');
          updateCount(-1);
          setTimeout(() => removeCard(submissionId), 1800);
        } catch (err) {
          setStatus(submissionId, `Error: ${err.message}`, 'error');
          setCardLoading(submissionId, false);
        }
      }

      // ── Reject ─────────────────────────────────────────
      async function handleReject(submissionId) {
        setCardLoading(submissionId, true);
        setStatus(submissionId, 'Deleting...', '');

        try {
          const res = await callAdmin({
            action: 'delete',
            password: sessionPassword,
            submissionId,
          });
          if (res.error) throw new Error(res.error);

          setStatus(submissionId, '❌ Rejected', 'error');
          updateCount(-1);
          setTimeout(() => removeCard(submissionId), 1200);
        } catch (err) {
          setStatus(submissionId, `Error: ${err.message}`, 'error');
          setCardLoading(submissionId, false);
        }
      }

      // ── Helpers ────────────────────────────────────────
      function setCardLoading(id, loading) {
        document.getElementById(`card-${id}`)
          ?.querySelectorAll('button')
          .forEach((b) => (b.disabled = loading));
      }

      function setStatus(id, message, type) {
        const el = document.getElementById(`status-${id}`);
        if (!el) return;
        el.textContent = message;
        el.className = `card-status ${type}`;
      }

      function removeCard(id) {
        const card = document.getElementById(`card-${id}`);
        if (!card) return;
        card.style.transition = 'opacity 0.3s, transform 0.3s';
        card.style.opacity = '0';
        card.style.transform = 'translateX(20px)';
        setTimeout(() => {
          card.remove();
          if (commentsContainer.children.length === 0) {
            emptyState.style.display = 'block';
            adminSubtitle.innerHTML = 'All caught up ✦';
          }
        }, 320);
      }

      let pendingCount = 0;
      function updateCount(delta) {
        pendingCount = Math.max(0, pendingCount + delta);
        if (pendingCount > 0) {
          adminSubtitle.innerHTML = `<span>${pendingCount} pending</span><span class="count-badge">${pendingCount}</span>`;
        }
      }

      function escHtml(str) {
        return String(str ?? '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');
      }
    </script>
  </body>
</html>