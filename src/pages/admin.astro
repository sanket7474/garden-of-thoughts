---
// src/pages/admin.astro
// Standalone — does NOT use Layout.astro or global.css
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin — Garden of Thoughts</title>
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;1,400&family=Cascadia+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box !important; margin: 0 !important; padding: 0 !important; }

      html, body {
        background: #0c0f24 !important;
        color: #f2f0e9 !important;
        font-family: 'Cascadia Mono', monospace !important;
        font-size: 14px !important;
        line-height: 1.6 !important;
        min-height: 100vh !important;
      }

      /* ── Login ─────────────────────────── */
      #login-screen {
        display: flex !important;
        flex-direction: column !important;
        align-items: center !important;
        justify-content: center !important;
        min-height: 100vh !important;
      }

      .login-box {
        width: 360px !important;
        background: #171a3a !important;
        border: 1px solid #c76399 !important;
        border-radius: 16px !important;
        padding: 2.5rem !important;
        display: flex !important;
        flex-direction: column !important;
        gap: 1.2rem !important;
      }

      .login-title {
        font-family: 'Lora', serif !important;
        font-size: 1.5rem !important;
        font-style: italic !important;
        color: #f2f0e9 !important;
        display: block !important;
      }

      .login-sub {
        font-size: 0.72rem !important;
        color: #9896a4 !important;
        text-transform: uppercase !important;
        letter-spacing: 0.08em !important;
        display: block !important;
        margin-top: 0.3rem !important;
      }

      .field-label {
        display: block !important;
        font-size: 0.7rem !important;
        text-transform: uppercase !important;
        letter-spacing: 0.08em !important;
        color: #9896a4 !important;
        margin-bottom: 0.4rem !important;
      }

      .field-input {
        display: block !important;
        width: 100% !important;
        background: rgba(255,255,255,0.06) !important;
        border: 1px solid rgba(199,99,153,0.4) !important;
        border-radius: 8px !important;
        padding: 0.65rem 1rem !important;
        font-size: 0.95rem !important;
        font-family: 'Cascadia Mono', monospace !important;
        color: #f2f0e9 !important;
        outline: none !important;
      }

      .field-input:focus { border-color: #c76399 !important; }

      .login-error {
        color: #f87171 !important;
        font-size: 0.78rem !important;
        display: none !important;
      }

      /* ── Buttons ───────────────────────── */
      .btn {
        font-family: 'Cascadia Mono', monospace !important;
        font-size: 0.82rem !important;
        font-weight: 500 !important;
        padding: 0.5rem 1.1rem !important;
        border-radius: 8px !important;
        border: none !important;
        cursor: pointer !important;
        display: inline-flex !important;
        align-items: center !important;
        gap: 0.3rem !important;
        transition: opacity 0.15s, transform 0.1s !important;
      }

      .btn:hover:not(:disabled) { opacity: 0.85 !important; transform: translateY(-1px) !important; }
      .btn:disabled { opacity: 0.35 !important; cursor: not-allowed !important; }

      .btn-login {
        background: #c76399 !important;
        color: #fff !important;
        width: 100% !important;
        justify-content: center !important;
        padding: 0.75rem !important;
        font-size: 0.95rem !important;
        border-radius: 10px !important;
      }

      .btn-approve {
        background: #0f2e14 !important;
        color: #4ade80 !important;
        border: 1px solid #1e5c28 !important;
      }

      .btn-reject {
        background: #2e0f0f !important;
        color: #f87171 !important;
        border: 1px solid #5c1e1e !important;
      }

      /* ── Admin page ────────────────────── */
      #admin-screen {
        display: none !important;
        max-width: 1100px !important;
        margin: 0 auto !important;
        padding: 2.5rem 1.5rem 5rem !important;
      }

      .admin-header {
        margin-bottom: 2rem !important;
        padding-bottom: 1.2rem !important;
        border-bottom: 1px dashed rgba(199,99,153,0.4) !important;
      }

      .admin-title {
        font-family: 'Lora', serif !important;
        font-size: 1.9rem !important;
        font-style: italic !important;
        color: #f2f0e9 !important;
        display: block !important;
      }

      .admin-sub {
        font-size: 0.72rem !important;
        color: #9896a4 !important;
        text-transform: uppercase !important;
        letter-spacing: 0.08em !important;
        margin-top: 0.35rem !important;
        display: block !important;
      }

      .count-pill {
        display: inline-block !important;
        background: rgba(199,99,153,0.15) !important;
        border: 1px solid rgba(199,99,153,0.4) !important;
        color: #c76399 !important;
        font-size: 0.7rem !important;
        padding: 0.1rem 0.55rem !important;
        border-radius: 20px !important;
        margin-left: 0.4rem !important;
        vertical-align: middle !important;
      }

      /* ── Grid ──────────────────────────── */
      .cards-grid {
        display: grid !important;
        grid-template-columns: repeat(auto-fill, minmax(400px, 1fr)) !important;
        gap: 1.2rem !important;
      }

      /* ── Card ──────────────────────────── */
      .card {
        background: #171a3a !important;
        border: 1px solid rgba(199,99,153,0.45) !important;
        border-left: 4px solid #c76399 !important;
        border-radius: 14px !important;
        padding: 1.4rem !important;
        display: flex !important;
        flex-direction: column !important;
        gap: 0.9rem !important;
        animation: fadeUp 0.3s ease both !important;
        transition: background 0.2s, transform 0.2s !important;
      }

      .card:hover {
        background: #1e2248 !important;
        transform: translateY(-2px) !important;
      }

      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(10px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      .card-top {
        display: flex !important;
        justify-content: space-between !important;
        align-items: flex-start !important;
        gap: 0.8rem !important;
      }

      .card-author { display: flex !important; flex-direction: column !important; gap: 0.2rem !important; }

      .card-name {
        font-size: 1rem !important;
        font-weight: 700 !important;
        color: #f2f0e9 !important;
        display: block !important;
      }

      .card-website {
        font-size: 0.75rem !important;
        color: #c76399 !important;
        text-decoration: none !important;
        display: block !important;
      }

      .card-website.no-site { color: #9896a4 !important; }

      .card-badges {
        display: flex !important;
        flex-direction: column !important;
        align-items: flex-end !important;
        gap: 0.3rem !important;
      }

      .pill {
        display: inline-block !important;
        font-size: 0.68rem !important;
        padding: 0.18rem 0.55rem !important;
        border-radius: 20px !important;
        white-space: nowrap !important;
        letter-spacing: 0.04em !important;
      }

      .pill-slug {
        background: rgba(134,124,192,0.18) !important;
        color: #a89fe0 !important;
        border: 1px solid rgba(134,124,192,0.3) !important;
      }

      .pill-date {
        background: rgba(255,255,255,0.05) !important;
        color: #c9c6d1 !important;
        border: 1px solid rgba(255,255,255,0.1) !important;
      }

      .section-label {
        font-size: 0.65rem !important;
        text-transform: uppercase !important;
        letter-spacing: 0.1em !important;
        color: #9896a4 !important;
        margin-bottom: 0.3rem !important;
        display: block !important;
      }

      .comment-body {
        font-family: sans-serif !important;
        font-size: 0.9rem !important;
        line-height: 1.65 !important;
        color: #f2f0e9 !important;
        background: rgba(0,0,0,0.3) !important;
        border-left: 3px solid #c76399 !important;
        border-radius: 0 8px 8px 0 !important;
        padding: 0.7rem 0.9rem !important;
        white-space: pre-wrap !important;
        word-break: break-word !important;
      }

      .post-link {
        display: inline-block !important;
        font-size: 0.75rem !important;
        color: #9896a4 !important;
        border: 1px solid rgba(255,255,255,0.1) !important;
        border-radius: 6px !important;
        padding: 0.25rem 0.65rem !important;
        text-decoration: none !important;
        transition: color 0.15s, border-color 0.15s !important;
      }

      .post-link:hover { color: #f2f0e9 !important; border-color: rgba(255,255,255,0.3) !important; }

      .card-actions {
        display: flex !important;
        align-items: center !important;
        gap: 0.6rem !important;
        flex-wrap: wrap !important;
      }

      .card-status {
        font-size: 0.78rem !important;
        margin-left: auto !important;
      }

      .card-status.success { color: #4ade80 !important; }
      .card-status.error   { color: #f87171 !important; }

      /* ── States ────────────────────────── */
      #loading, #empty-state {
        text-align: center !important;
        padding: 4rem 0 !important;
        color: #9896a4 !important;
        font-size: 0.85rem !important;
        letter-spacing: 0.04em !important;
      }

      .error-banner {
        background: rgba(219,92,85,0.1) !important;
        border: 1px solid rgba(219,92,85,0.35) !important;
        color: #f87171 !important;
        padding: 1rem 1.2rem !important;
        border-radius: 10px !important;
        margin-bottom: 1.2rem !important;
        font-size: 0.82rem !important;
      }
    </style>
  </head>
  <body>

    <!-- Login -->
    <div id="login-screen">
      <div class="login-box">
        <div>
          <span class="login-title">🌱 Garden of Thoughts</span>
          <span class="login-sub">Admin · Comment Moderation</span>
        </div>
        <div>
          <label class="field-label" for="pw">Password</label>
          <input class="field-input" type="password" id="pw" placeholder="Enter password" autocomplete="current-password" />
        </div>
        <p id="login-error" class="login-error">Incorrect password. Try again.</p>
        <button class="btn btn-login" id="login-btn">Enter</button>
      </div>
    </div>

    <!-- Admin -->
    <div id="admin-screen">
      <div class="admin-header">
        <span class="admin-title">Comment Moderation</span>
        <span class="admin-sub" id="admin-sub">Loading...</span>
      </div>
      <div id="error-container"></div>
      <div id="loading">Fetching pending comments...</div>
      <div class="cards-grid" id="cards-grid"></div>
      <div id="empty-state" style="display:none">✦ No pending comments — you're all caught up</div>
    </div>

    <script>
      let sessionPassword = null;
      let allSubmissions = [];

      const loginScreen  = document.getElementById('login-screen');
      const adminScreen  = document.getElementById('admin-screen');
      const loginBtn     = document.getElementById('login-btn');
      const pwInput      = document.getElementById('pw');
      const loginError   = document.getElementById('login-error');
      const cardsGrid    = document.getElementById('cards-grid');
      const emptyState   = document.getElementById('empty-state');
      const loadingEl    = document.getElementById('loading');
      const adminSub     = document.getElementById('admin-sub');
      const errorCont    = document.getElementById('error-container');

      loginBtn.addEventListener('click', handleLogin);
      pwInput.addEventListener('keydown', e => { if (e.key === 'Enter') handleLogin(); });

      async function handleLogin() {
        loginBtn.disabled = true;
        loginBtn.textContent = 'Verifying...';
        loginError.style.display = 'none';
        const password = pwInput.value;
        const res = await callAdmin({ action: 'list', password });
        if (res.error === 'Unauthorized') {
          loginError.style.display = 'block';
          pwInput.value = '';
          loginBtn.disabled = false;
          loginBtn.textContent = 'Enter';
          return;
        }
        sessionPassword = password;
        loginScreen.style.display = 'none';
        adminScreen.style.display = 'block';
        allSubmissions = res.submissions || [];
        loadingEl.style.display = 'none';
        updateSubtitle();
        renderCards();
      }

      async function callAdmin(body) {
        try {
          const r = await fetch('/api/admin-submissions', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });
          return r.json();
        } catch(e) { return { error: e.message }; }
      }

      function updateSubtitle() {
        const n = allSubmissions.length;
        adminSub.innerHTML = n === 0
          ? 'All caught up ✦'
          : `${n} pending <span class="count-pill">${n}</span>`;
      }

      function renderCards() {
        cardsGrid.innerHTML = '';
        if (allSubmissions.length === 0) { emptyState.style.display = 'block'; return; }

        allSubmissions.forEach((sub, i) => {
          const { id, data, created_at } = sub;
          const { name, comment, slug, website } = data;
          const date = new Date(created_at).toLocaleDateString('en-US', {
            month: 'short', day: 'numeric', year: 'numeric',
            hour: '2-digit', minute: '2-digit'
          });

          const card = document.createElement('div');
          card.className = 'card';
          card.id = `card-${id}`;
          card.style.animationDelay = `${i * 60}ms`;

          card.innerHTML = `
            <div class="card-top">
              <div class="card-author">
                <span class="card-name">👤 ${esc(name)}</span>
                ${website
                  ? `<a class="card-website" href="${esc(website)}" target="_blank" rel="noopener">⤤ ${esc(website)}</a>`
                  : `<span class="card-website no-site">No website</span>`}
              </div>
              <div class="card-badges">
                <span class="pill pill-slug">📄 ${esc(slug)}</span>
                <span class="pill pill-date">🕐 ${date}</span>
              </div>
            </div>

            <div>
              <span class="section-label">Comment</span>
              <div class="comment-body">${esc(comment)}</div>
            </div>

            <div>
              <span class="section-label">Post</span>
              <a class="post-link" href="/blog/${esc(slug)}" target="_blank" rel="noopener">/blog/${esc(slug)} ↗</a>
            </div>

            <div class="card-actions">
              <button class="btn btn-approve" data-id="${id}">✅ Approve</button>
              <button class="btn btn-reject"  data-id="${id}">❌ Reject</button>
              <span class="card-status" id="status-${id}"></span>
            </div>
          `;
          cardsGrid.appendChild(card);
        });

        document.querySelectorAll('.btn-approve').forEach(b =>
          b.addEventListener('click', () => handleApprove(b.dataset.id)));
        document.querySelectorAll('.btn-reject').forEach(b =>
          b.addEventListener('click', () => handleReject(b.dataset.id)));
      }

      async function handleApprove(id) {
        const sub = allSubmissions.find(s => s.id === id);
        setLoading(id, true);
        setStatus(id, 'Pushing to GitHub...', '');
        try {
          const r = await fetch('/api/comment-approved', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ data: sub.data }),
          });
          if (!r.ok) throw new Error('GitHub push failed');
          const d = await callAdmin({ action: 'delete', password: sessionPassword, submissionId: id });
          if (d.error) throw new Error(d.error);
          setStatus(id, '✅ Approved & live soon!', 'success');
          removeSubmission(id);
          setTimeout(() => removeCard(id), 1800);
        } catch(e) {
          setStatus(id, `Error: ${e.message}`, 'error');
          setLoading(id, false);
        }
      }

      async function handleReject(id) {
        setLoading(id, true);
        setStatus(id, 'Deleting...', '');
        try {
          const d = await callAdmin({ action: 'delete', password: sessionPassword, submissionId: id });
          if (d.error) throw new Error(d.error);
          setStatus(id, '❌ Rejected', 'error');
          removeSubmission(id);
          setTimeout(() => removeCard(id), 1200);
        } catch(e) {
          setStatus(id, `Error: ${e.message}`, 'error');
          setLoading(id, false);
        }
      }

      function removeSubmission(id) {
        allSubmissions = allSubmissions.filter(s => s.id !== id);
        updateSubtitle();
      }

      function removeCard(id) {
        const card = document.getElementById(`card-${id}`);
        if (!card) return;
        card.style.transition = 'opacity 0.3s, transform 0.3s';
        card.style.opacity = '0';
        card.style.transform = 'scale(0.96)';
        setTimeout(() => {
          card.remove();
          if (cardsGrid.children.length === 0) emptyState.style.display = 'block';
        }, 320);
      }

      function setLoading(id, v) {
        document.getElementById(`card-${id}`)?.querySelectorAll('button').forEach(b => b.disabled = v);
      }

      function setStatus(id, msg, type) {
        const el = document.getElementById(`status-${id}`);
        if (el) { el.textContent = msg; el.className = `card-status ${type}`; }
      }

      function esc(s) {
        return String(s ?? '')
          .replace(/&/g,'&amp;').replace(/</g,'&lt;')
          .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
      }
    </script>
  </body>
</html>