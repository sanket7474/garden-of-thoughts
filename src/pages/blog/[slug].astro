---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import DocumentHead from "../../layouts/DocumentHead.astro";
import Comments from "../../layouts/Comments.astro";
import TagsList from "../../layouts/TagsList.astro";
import YouTubeScript from "../../layouts/YouTubeScript.astro";

const { slug } = Astro.params;
const { note } = Astro.props;


export async function getStaticPaths() {
  const notes = await getCollection("posts");
  return [
    ...notes.map((note) => ({
      params: { slug: note.id.replace(".md", "").replace(".mdx", "") },
      props: { note },
    })),
  ];
}

export function formatDate(date:any) {
  return date.toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
  });
}
const {
  data: { tags, title, noComments, date, minutesRead, excerpt},
} = note;

const { Content } = await render(note);

const includeYTResources = note.body.includes('lite-youtube');

const permalink = "https://sanketmaske.dev/${slug}/";

const titleEncoded = encodeURIComponent(`re: ${title}`);
---

<style>
  h1 {
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    margin-bottom: 0;
    line-height: 1;
  }

  .meta {
    margin: 2em 0;
    padding: 0.5em 0;
    border-top: 1px dashed var(--text-color);
    color: var(--second-text-color);
  }

  .meta .tags {
    list-style: none;
    display: flex;
    margin: 0;
    padding: 0;
  }

  .meta .added-updated {
    font-size: 0.9em;
    text-transform: uppercase;
  }

  :global(#footnote-label) {
    font-size: 1.2rem;
    text-transform: uppercase;
  }

  .thanks-for-reading {
    margin: 4rem 0;
  }
  
/* tags-row wrapper */
.tags-row {
  display: inline-block;
  flex-wrap: wrap;
  gap: 2px 0;
  align-items: center;
  
}
.prose {

  color: var(--text);
}

.prose p { margin-bottom: 26px; }

.prose::first-letter {
  
  font-size: 3.4em;
  float: left;
  line-height: .82;
  margin-right: 6px;
  margin-top: 5px;
  color: var(--red);
  font-style: italic;
}

.prose strong { font-weight: 500; }

.article-meta {
  font-size: 0.9em;
  margin: 2em 0em;
}
.article-date {

  text-transform: uppercase
}
.article-minutes {
 
}



</style>

<html lang="en">
  <DocumentHead title={title} description={excerpt || ''} permalink={permalink} canonicalUrl={permalink} includeYTResources={includeYTResources} />
  <body>
    <Layout page="note">
      <article class="article-wrap">
        <h1 class="article-h1">{title}</h1>
        
        <div class="article-meta">
          <span class="article-date">📅 {formatDate(date)}</span>
          <span class="meta-dot">·</span>
          <span class="article-minutes">⌚ {minutesRead} mins read</span>
          <span class="meta-dot">·</span>
          <span class="article-views" id="view-count">⌛loading views...</span>
          <div class="article-meta">
            <TagsList tags={tags} />
          </div>
          <hr>
        </div>
         <div class="prose styled-link-underlines">
          <Content />
         </div>
      </article>
      <section class="styled-link-underlines thanks-for-reading">
        <b>Thanks for reading!</b> If you'd like to share your thoughts you can
        <a href={`/blog/${slug}/#comments`}>leave a comment</a>, <a
          href={`mailto:sanket.maske@outlook.com?subject=${titleEncoded}`}
          >send me an email</a
        >
      </section>
      <Comments slug={slug} noComments={noComments} />
    </Layout>
    {includeYTResources && <YouTubeScript />}
  </body>

  <script>
  // @ts-nocheck
     // @ts-ignore
  document.querySelectorAll('.tags-row').forEach(title => {
    const tags = title.querySelectorAll('.tag');
    const colors = ['var(--red)', 'var(--orange)', 'var(--pink)', 'var(--green)', 'var(--light-blue)', 'var(--purple)', 'var(--blue)'];
    const shuffled = colors.sort(() => Math.random() - 0.5);
    tags.forEach((tag, i) => {
      tag.style.color = shuffled[i % shuffled.length];
    });
  });

  const slug = window.__slug || document.location.pathname.split('/blog/')[1]?.replace('/', '');
  
  // Increment on visit
  fetch(`/api/post-view?slug=${slug}`, { method: 'POST' })
    .then(r => r.json())
    .then(data => {
      const el = document.getElementById('view-count');
      if (el) el.textContent = `👁️ ${data.views} view${data.views === 1 ? '' : 's'}`;
    });
  
</script>
</html>
