---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import DocumentHead from "../../layouts/DocumentHead.astro";
import Comments from "../../layouts/Comments.astro";

const { slug } = Astro.params;
const { note } = Astro.props;


export async function getStaticPaths() {
  const notes = await getCollection("posts");
  
  return [
    ...notes.map((note) => ({
      params: { slug: note.id.replace(".md", "") },
      props: { note },
    })),
  ];
}

export function formatDate(date:any) {
  return date.toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
  });
}
const {
  data: { tags, title, noComments },
} = note;

const { Content } = await render(note);

const permalink = "{URL}";

const titleEncoded = encodeURIComponent(`re: ${title}`);
---

<style>
  h1 {
    font-size: 2.5rem;
    margin-bottom: 0;
    line-height: 1;
  }

  .meta {
    margin: 2em 0;
    padding: 0.5em 0;
    border-top: 1px dashed var(--text-color);
    color: var(--second-text-color);
  }

  .meta .tags {
    list-style: none;
    display: flex;
    margin: 0;
    padding: 0;
  }

  .meta .added-updated {
    font-size: 0.9em;
    text-transform: uppercase;
  }

  :global(#footnote-label) {
    font-size: 1.2rem;
    text-transform: uppercase;
  }

  .thanks-for-reading {
    margin: 4rem 0;
  }
  
/* tags-row wrapper */
.tags-row {
  display: inline-block;
  flex-wrap: wrap;
  gap: 2px 0;
  align-items: center;
}
.prose {

  color: var(--text);
}

.prose p { margin-bottom: 26px; }

.prose::first-letter {
  
  font-size: 3.4em;
  float: left;
  line-height: .82;
  margin-right: 6px;
  margin-top: 5px;
  color: var(--red);
  font-style: italic;
}

.prose strong { font-weight: 500; }

.article-meta {
  margin-top: 1em;
}
</style>

<html lang="en">
  <DocumentHead title={title} description="" permalink={permalink} />
  <body>
    <Layout page="note">
      <article class="article-wrap">
        <h1 class="article-h1">{title}</h1>
        
        <div class="article-meta">
          <span class="article-date">25 feb 2026</span>
          <span class="meta-dot">·</span>
          <div class="tags-row">
            <a href="#" class="tag">#life</a>
            <a href="#" class="tag">#learning</a>
            <a href="#" class="tag">#photography</a>
            <a href="#" class="tag">#27</a>
          </div>

        </div>
         <div class="prose">
          <Content />
         </div>
      </article>
      <section class="styled-link-underlines thanks-for-reading">
        <b>Thanks for reading!</b> If you'd like to share your thoughts you can
        <a href={`/blog/${slug}/#comments`}>leave a comment</a>, <a
          href={`mailto:sanket.maske@outlook.com?subject=${titleEncoded}`}
          >send me an email</a
        >
      </section>
      <Comments slug={slug} noComments={noComments} />
    </Layout>
  </body>
</html>
