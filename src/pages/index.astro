---
// Component Imports
import DocumentHead from '../layouts/DocumentHead.astro';
import Layout from '../layouts/Layout.astro';
import HomeNotes from '../layouts/HomeNotes.astro';

let title = `Home | Sanket Maske's digital garden`;
let description = `Hi 👋 I'm Sanket. A developer, occasional photographer, and someone who 
thinks too much and writes about it. This is my digital garden.`;
let permalink = 'https://sanketmaske.dev';

let page = 'posts';
---




<html lang="en">
  <DocumentHead title={title} description={description} permalink={permalink} canonicalUrl={permalink} />
  <body>
    <Layout page={page}>
      <HomeNotes />
    </Layout>
  </body>
</html>